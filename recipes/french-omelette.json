{
  "title": "French Omelette",
  "servings": 1,
  "cuisine": "French",
  "vegetarian": true,
  "sweet": false,
  "time_minutes": 10,
  "prep_minutes": 0,
  "devices": [
    {
      "id": "hob",
      "name": "Hob",
      "settings": "medium-high heat"
    },
    {
      "id": "pan",
      "name": "Non-stick Pan"
    },
    {
      "id": "bowl",
      "name": "Mixing Bowl"
    },
    {
      "id": "chopping_board",
      "name": "Chopping Board"
    }
  ],
  "ingredients": [
    {
      "id": "eggs",
      "name": "Eggs",
      "quantity": "3"
    },
    {
      "id": "butter",
      "name": "Butter",
      "quantity": "15g"
    },
    {
      "id": "chives",
      "name": "Fresh Chives",
      "quantity": "1 tbsp"
    },
    {
      "id": "salt",
      "name": "Salt",
      "quantity": "pinch"
    },
    {
      "id": "pepper",
      "name": "Black Pepper",
      "quantity": "pinch"
    }
  ],
  "steps": [
    {
      "id": "beat_eggs",
      "device": "bowl",
      "action": "Crack eggs into bowl and beat with a fork until just combined",
      "inputs": [
        "eggs"
      ],
      "output": "beaten_eggs",
      "end": {
        "duration_minutes": 1
      }
    },
    {
      "id": "season",
      "device": "bowl",
      "action": "Season beaten eggs with salt and pepper",
      "inputs": [
        "beaten_eggs",
        "salt",
        "pepper"
      ],
      "output": "seasoned_eggs",
      "after": "beat_eggs",
      "end": {
        "duration_minutes": 0.5
      }
    },
    {
      "id": "chop_chives",
      "device": "chopping_board",
      "action": "Finely snip chives with scissors or a knife",
      "inputs": [
        "chives"
      ],
      "output": "chopped_chives",
      "end": {
        "duration_minutes": 1
      }
    },
    {
      "id": "heat_butter",
      "device": "pan",
      "action": "Melt butter in pan over medium-high heat until foaming",
      "inputs": [
        "butter"
      ],
      "output": "hot_butter",
      "after": "season",
      "end": {
        "condition": "butter foaming but not browning"
      }
    },
    {
      "id": "cook_omelette",
      "device": "pan",
      "action": "Pour in seasoned eggs, stir briefly with a fork, then let set while tilting pan to spread uncooked egg",
      "inputs": [
        "hot_butter",
        "seasoned_eggs"
      ],
      "output": "cooked_omelette",
      "after": [
        "season",
        "heat_butter"
      ],
      "end": {
        "duration_minutes": 2,
        "condition": "just set on top, golden underneath"
      }
    },
    {
      "id": "fold_and_plate",
      "device": "pan",
      "action": "Fold omelette in thirds and slide onto a warm plate",
      "inputs": [
        "cooked_omelette"
      ],
      "output": "plated_omelette",
      "after": "cook_omelette",
      "end": {
        "duration_minutes": 0.5
      }
    },
    {
      "id": "garnish_chives",
      "device": "chopping_board",
      "action": "Scatter chopped chives over the plated omelette",
      "inputs": [
        "plated_omelette",
        "chopped_chives"
      ],
      "output": "french_omelette",
      "after": [
        "fold_and_plate",
        "chop_chives"
      ],
      "end": {
        "duration_minutes": 0.5
      }
    }
  ]
}
