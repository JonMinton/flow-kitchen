  "steps": [
    {
      "id": "make_dough",
      "device": "saucepan",
      "action": "Make churro dough",
      "inputs": [
        "water",
        "butter",
        "sugar",
        "salt",
        "flour"
      ],
      "output": "rested_dough",
      "end": {
        "condition": "dough rested and ready to pipe"
      },
      "steps": [
        {
          "id": "heat_water",
          "device": "saucepan",
          "action": "Heat water, butter, 1 tbsp sugar and salt until butter melts and mixture boils",
          "inputs": [
            "water",
            "butter",
            "sugar",
            "salt"
          ],
          "output": "hot_liquid",
          "end": {
            "duration_minutes": 3,
            "condition": "rolling boil with butter fully melted"
          }
        },
        {
          "id": "add_flour",
          "device": "saucepan",
          "action": "Remove from heat and stir in flour vigorously until dough forms a ball",
          "inputs": [
            "hot_liquid",
            "flour"
          ],
          "output": "raw_dough",
          "after": "heat_water",
          "end": {
            "duration_minutes": 2,
            "condition": "smooth dough that pulls away from the sides"
          }
        },
        {
          "id": "rest_dough",
          "device": "worktop",
          "action": "Transfer dough to piping bag with star nozzle and let rest briefly",
