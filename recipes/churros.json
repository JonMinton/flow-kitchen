        "duration_minutes": 1
      }
    },
    {
      "id": "heat_oil",
      "device": "deep_pan",
      "action": "Heat the oil in a deep pan to 180°C",
      "inputs": [
        "oil"
      ],
      "output": "hot_oil",
      "end": {
        "duration_minutes": 5,
        "condition": "oil at 180°C — a cube of bread browns in about 30 seconds"
      }
    },
    {
      "id": "fry_churros",
      "device": "deep_pan",
      "action": "Pipe dough into hot oil and fry in batches until golden and crisp",
      "inputs": [
        "rested_dough",
        "hot_oil"
      ],
      "output": "fried_churros",
      "after": "heat_oil",
      "end": {
        "duration_minutes": 8,
        "condition": "deep golden brown and crisp all over"
      }
    },
    {
      "id": "coat_churros",
      "device": "mixing_bowl",
      "action": "Toss hot churros in cinnamon sugar",
      "inputs": [
        "fried_churros",
        "cinnamon_sugar"
      ],
      "output": "coated_churros",
      "after": [
        "fry_churros",
        "make_cinnamon_sugar"
