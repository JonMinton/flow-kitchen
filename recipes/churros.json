          "inputs": [
            "cream"
          ],
          "output": "hot_cream",
          "end": {
            "duration_minutes": 2,
            "condition": "small bubbles around the edge"
          }
        },
        {
          "id": "melt_chocolate",
          "device": "small_saucepan",
          "action": "Remove from heat, add chopped chocolate and stir until smooth",
          "inputs": [
            "hot_cream",
            "dark_chocolate"
          ],
          "output": "chocolate_sauce",
          "after": "heat_cream",
          "end": {
            "duration_minutes": 2,
            "condition": "smooth, glossy and thick"
          }
        }
      ]
    },
