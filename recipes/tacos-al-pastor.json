{
  "title": "Tacos al Pastor",
  "servings": 4,
  "cuisine": "Mexican",
  "vegetarian": false,
  "sweet": false,
  "time_minutes": 165,
  "prep_minutes": 120,
  "devices": [
    {
      "id": "hob",
      "name": "Hob"
    },
    {
      "id": "oven",
      "name": "Oven"
    },
    {
      "id": "pan",
      "name": "Pan"
    },
    {
      "id": "chopping_board",
      "name": "Chopping Board"
    },
    {
      "id": "blender",
      "name": "Blender"
    },
    {
      "id": "bowl",
      "name": "Bowl"
    }
  ],
  "ingredients": [
    {
      "id": "pork_shoulder",
      "name": "Pork Shoulder",
      "quantity": "800g"
    },
    {
      "id": "guajillo_chillies",
      "name": "Dried Guajillo Chillies",
      "quantity": "6"
    },
    {
      "id": "achiote_paste",
      "name": "Achiote Paste",
      "quantity": "2 tbsp"
    },
    {
      "id": "pineapple",
      "name": "Pineapple",
      "quantity": "1/2, peeled"
    },
    {
      "id": "garlic",
      "name": "Garlic",
      "quantity": "4 cloves"
    },
    {
      "id": "cumin",
      "name": "Cumin",
      "quantity": "1 tsp"
    },
    {
      "id": "oregano",
      "name": "Oregano",
      "quantity": "1 tsp"
    },
    {
      "id": "vinegar",
      "name": "White Vinegar",
      "quantity": "2 tbsp"
    },
    {
      "id": "vegetable_oil",
      "name": "Vegetable Oil",
      "quantity": "2 tbsp"
    },
    {
      "id": "corn_tortillas",
      "name": "Corn Tortillas",
      "quantity": "12"
    },
    {
      "id": "coriander",
      "name": "Fresh Coriander",
      "quantity": "large bunch"
    },
    {
      "id": "lime",
      "name": "Lime",
      "quantity": "2"
    },
    {
      "id": "white_onion",
      "name": "White Onion",
      "quantity": "1"
    },
    {
      "id": "salt",
      "name": "Salt",
      "quantity": "to taste"
    }
  ],
  "steps": [
    {
      "id": "make_marinade",
      "device": "blender",
      "action": "Make al pastor marinade from toasted chillies and spices",
      "inputs": [
        "guajillo_chillies",
        "achiote_paste",
        "garlic",
        "cumin",
        "oregano",
        "vinegar",
        "pineapple",
        "salt"
      ],
      "output": "marinade",
      "end": {
        "condition": "smooth, vibrant red marinade"
      },
      "steps": [
        {
          "id": "prepare_chillies",
          "device": "hob",
          "action": "Toast and rehydrate dried chillies",
          "inputs": [
            "guajillo_chillies"
          ],
          "output": "rehydrated_chillies",
          "end": {
            "condition": "chillies softened and pliable"
          },
          "steps": [
            {
              "id": "deseed_chillies",
              "device": "chopping_board",
              "action": "Remove stems and seeds from dried guajillo chillies",
              "inputs": [
                "guajillo_chillies"
              ],
              "output": "deseeded_chillies",
              "end": {
                "duration_minutes": 3
              }
            },
            {
              "id": "toast_chillies",
              "device": "pan",
              "action": "Toast chillies in a dry pan until fragrant and pliable",
              "after": "deseed_chillies",
              "inputs": [
                "deseeded_chillies"
              ],
              "output": "toasted_chillies",
              "end": {
                "duration_minutes": 2,
                "condition": "fragrant, slightly darkened"
              }
            },
            {
              "id": "soak_chillies",
              "device": "bowl",
              "action": "Soak toasted chillies in hot water until soft",
              "after": "toast_chillies",
              "inputs": [
                "toasted_chillies"
              ],
              "output": "rehydrated_chillies",
              "end": {
                "duration_minutes": 15,
                "condition": "fully softened"
              }
            }
          ]
        },
        {
          "id": "extract_pineapple_juice",
          "device": "chopping_board",
          "action": "Cut pineapple and reserve juice for marinade",
          "inputs": [
            "pineapple"
          ],
          "output": "pineapple_juice",
          "end": {
            "duration_minutes": 3
          }
        },
        {
          "id": "blend_marinade",
          "device": "blender",
          "action": "Blend rehydrated chillies with achiote, garlic, spices, vinegar and pineapple juice",
          "after": [
            "prepare_chillies",
            "extract_pineapple_juice"
          ],
          "inputs": [
            "rehydrated_chillies",
            "achiote_paste",
            "garlic",
            "cumin",
            "oregano",
            "vinegar",
            "pineapple_juice",
            "salt"
          ],
          "output": "marinade",
          "end": {
            "duration_minutes": 3,
            "condition": "smooth paste"
          }
        }
      ]
    },
    {
      "id": "marinate_pork",
      "device": "bowl",
      "action": "Slice pork, coat in marinade and rest",
      "after": "make_marinade",
      "inputs": [
        "pork_shoulder",
        "marinade"
      ],
      "output": "marinated_pork",
      "end": {
        "duration_minutes": 120,
        "condition": "pork deeply flavoured"
      },
      "steps": [
        {
          "id": "slice_pork",
          "device": "chopping_board",
          "action": "Slice pork shoulder into thin steaks about 5mm thick",
          "inputs": [
            "pork_shoulder"
          ],
          "output": "sliced_pork",
          "end": {
            "duration_minutes": 5
          }
        },
        {
          "id": "coat_pork",
          "device": "bowl",
          "action": "Coat pork slices thoroughly in marinade",
          "after": "slice_pork",
          "inputs": [
            "sliced_pork",
            "marinade"
          ],
          "output": "coated_pork",
          "end": {
            "duration_minutes": 3
          }
        },
        {
          "id": "rest_pork",
          "device": "bowl",
          "action": "Cover and refrigerate to marinate for at least 2 hours",
          "after": "coat_pork",
          "inputs": [
            "coated_pork"
          ],
          "output": "marinated_pork",
          "end": {
            "duration_minutes": 120,
            "condition": "flavours penetrated the meat"
          }
        }
      ]
    },
    {
      "id": "cook_pork",
      "device": "pan",
      "action": "Cook marinated pork until charred and caramelised",
      "after": "marinate_pork",
      "inputs": [
        "marinated_pork",
        "vegetable_oil"
      ],
      "output": "cooked_pork",
      "end": {
        "condition": "charred edges, cooked through"
      },
      "steps": [
        {
          "id": "heat_pan",
          "device": "pan",
          "action": "Heat a heavy pan or griddle over high heat with oil",
          "inputs": [
            "vegetable_oil"
          ],
          "output": "hot_pan",
          "end": {
            "duration_minutes": 2,
            "condition": "pan smoking hot"
          }
        },
        {
          "id": "sear_pork",
          "device": "pan",
          "action": "Cook pork slices in batches until charred on both sides",
          "after": "heat_pan",
          "inputs": [
            "marinated_pork",
            "hot_pan"
          ],
          "output": "seared_pork",
          "end": {
            "duration_minutes": 12,
            "condition": "charred edges, cooked through"
          }
        },
        {
          "id": "rest_and_slice",
          "device": "chopping_board",
          "action": "Rest briefly then slice pork into thin strips",
          "after": "sear_pork",
          "inputs": [
            "seared_pork"
          ],
          "output": "cooked_pork",
          "end": {
            "duration_minutes": 5
          }
        }
      ]
    },
    {
      "id": "caramelize_pineapple",
      "device": "pan",
      "action": "Caramelise pineapple slices in the pork pan",
      "after": "cook_pork",
      "inputs": [
        "pineapple"
      ],
      "output": "caramelised_pineapple",
      "end": {
        "condition": "golden and caramelised"
      },
      "steps": [
        {
          "id": "slice_pineapple",
          "device": "chopping_board",
          "action": "Cut remaining pineapple into thin half-moons",
          "inputs": [
            "pineapple"
          ],
          "output": "pineapple_slices",
          "end": {
            "duration_minutes": 2
          }
        },
        {
          "id": "grill_pineapple",
          "device": "pan",
          "action": "Grill pineapple slices in the hot pan until charred",
          "after": "slice_pineapple",
          "inputs": [
            "pineapple_slices"
          ],
          "output": "charred_pineapple",
          "end": {
            "duration_minutes": 4,
            "condition": "golden char marks on both sides"
          }
        },
        {
          "id": "dice_pineapple",
          "device": "chopping_board",
          "action": "Roughly dice the caramelised pineapple",
          "after": "grill_pineapple",
          "inputs": [
            "charred_pineapple"
          ],
          "output": "caramelised_pineapple",
          "end": {
            "duration_minutes": 2
          }
        }
      ]
    },
    {
      "id": "prep_toppings",
      "device": "chopping_board",
      "action": "Prepare fresh toppings",
      "inputs": [
        "white_onion",
        "coriander",
        "lime"
      ],
      "output": "toppings",
      "end": {
        "condition": "all toppings ready"
      },
      "steps": [
        {
          "id": "dice_white_onion",
          "device": "chopping_board",
          "action": "Finely dice white onion",
          "inputs": [
            "white_onion"
          ],
          "output": "diced_onion",
          "end": {
            "duration_minutes": 3
          }
        },
        {
          "id": "chop_coriander",
          "device": "chopping_board",
          "action": "Roughly chop fresh coriander leaves and tender stems",
          "inputs": [
            "coriander"
          ],
          "output": "chopped_coriander",
          "end": {
            "duration_minutes": 2
          }
        },
        {
          "id": "cut_lime_wedges",
          "device": "chopping_board",
          "action": "Cut limes into wedges",
          "inputs": [
            "lime"
          ],
          "output": "lime_wedges",
          "end": {
            "duration_minutes": 1
          }
        }
      ]
    },
    {
      "id": "warm_tortillas",
      "device": "pan",
      "action": "Warm corn tortillas on a dry pan",
      "inputs": [
        "corn_tortillas"
      ],
      "output": "warm_tortillas",
      "end": {
        "duration_minutes": 4,
        "condition": "pliable and lightly charred"
      }
    },
    {
      "id": "assemble_tacos",
      "device": "chopping_board",
      "action": "Assemble tacos with pork, pineapple and fresh toppings",
      "after": [
        "cook_pork",
        "caramelize_pineapple",
        "prep_toppings",
        "warm_tortillas"
      ],
      "inputs": [
        "warm_tortillas",
        "cooked_pork",
        "caramelised_pineapple",
        "toppings"
      ],
      "output": "tacos_al_pastor",
      "end": {
        "duration_minutes": 5,
        "condition": "tacos assembled and ready to serve"
      }
    }
  ]
}
