          "device": "dutch_oven",
          "action": "Scatter fresh parsley over the top",
          "after": "check_seasoning",
          "inputs": [
            "seasoned_stew",
            "parsley"
          ],
          "output": "beef_bourguignon",
          "end": {
            "duration_minutes": 1
          }
        }
