  "steps": [
    {
      "id": "prep",
      "device": "chopping_board",
      "action": "Prepare all ingredients",
      "inputs": [
        "chicken_thighs",
        "andouille_sausage",
        "onion",
        "celery",
        "green_pepper",
        "garlic",
        "spring_onions"
